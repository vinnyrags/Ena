{
  "name": "ena",
  "version": "0.1.0",
  "description": "Starter child theme for Mythus + IX",
  "private": true,
  "scripts": {
    "build-parent": "npm --prefix ../ix run build",
    "build-providers": "node ../ix/scripts/build-providers.js",
    "watch-providers": "node ../ix/scripts/build-providers.js --watch",
    "build": "npm run build-parent && npm run build-providers",
    "watch-parent": "npm --prefix ../ix run start",
    "start": "npm-run-all --parallel watch-parent watch-providers"
  },
  "devDependencies": {
    "esbuild": "^0.25.1",
    "npm-run-all": "^4.1.5",
    "sass": "^1.86.0"
  }
}
