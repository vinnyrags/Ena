{
  "name": "vincentragosta/ena",
  "description": "Starter child theme for projects on Mythus + IX",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Vincent Ragosta"
    }
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://packages.vincentragosta.io"
    },
    {
      "type": "composer",
      "url": "https://wpackagist.org"
    }
  ],
  "require": {
    "php": ">=8.4",
    "vincentragosta/mythus": "^1.0",
    "vincentragosta/ix": "^1.0",
    "timber/timber": "2.x-dev"
  },
  "autoload": {
    "psr-4": {
      "Ena\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": false
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
